@startuml
title Two-Side PR Cases for a .model File

start

:File path matches a configured model extension;

if (File differs between PR source and target?) then (yes)
  if (File status?) then (added)
    :Case: added in source branch;
  elseif (deleted)
    :Case: deleted in source branch;
  elseif (renamed/moved)
    :Case: renamed or moved model file;
  else (modified)
    :Case: modified model file;
  endif

  :Resolve source version if present;
  :Resolve target version if present;

  if (Can all required versions be loaded?) then (yes)
    if (Do all loaded versions conform to the resolved metamodel?) then (yes)
      if (Do both source and target versions exist?) then (yes)
        if (Any semantic model difference?) then (yes)
          :Case: semantic model change;
          :Report outcome: semantic changes;
        else (no)
          :Case: textual-only change;
          :Report outcome: relevant file but no semantic model change;
        endif
      else (no)
        if (Source version exists?) then (yes)
          :Case: model creation;
          :Report outcome: model was created;
        else (no)
          :Case: model deletion;
          :Report outcome: model was deleted;
        endif
      endif
    else (no)
      :Case: metamodel conformance failure;
      :Report outcome: analysis incomplete or invalid model;
    endif
  else (no)
    :Case: parse/load failure;
    :Report outcome: analysis incomplete;
  endif
else (no)
  :Case: unchanged at PR tip;
  :RAMA generates "No changes detected" report;
endif

:Report posted as PR comment;

stop
@enduml
