@startuml pr-model-file-cases-all
title PR Cases for a model file

start

:File path matches a configured model extension;

if (Can source and target versions be loaded?) then (yes)
  if (Do they conform to the resolved metamodel?) then (yes)

    if (Are there changes in both branches?) then (yes)
      :Case: 3-way comparison;
    else (no)
      :Case: 2-way comparison;
    endif

  else (no)
    :Case: metamodel conformance failure;
    :Report outcome: analysis incomplete or invalid model;
  endif
else (no)
  :Case: parse/load failure;
  :Report outcome: analysis incomplete;
endif

:Report posted as PR comment;

stop
@enduml